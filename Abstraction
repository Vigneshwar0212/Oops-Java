// same as the above -> but created a object for a class using interface as a referance variable

interface shape{  

	int length = 10;  //final and static variable in default 
    int widgth = 20;

    void circle(); //abstract method (cannot implements value to it)
    
    default void rectangle(){   //default method (provide less visiblity than public, mostly used in interface) -> can be implements value like this method (can print values)
        System.out.println("Rectangle method - default keyword");
    }
    static void square(){  /*static method can be accessed any where in the class -> its kind of common (ex: school name, clg exam center) -> can be accessed 
                            without creating an object -> can be accessed by calling the class name */
        System.out.println("Square method - static keyword");
    }
}


public class Main implements shape  //if a class wants to inherit interface -> then implements keyword should be used
{
    public void circle(){  /*As it is abstract method declared in the interface, it should be declared in class also for implementation -> declare a 
                            public keyword to this method as declared as in interface (public in default in interface) */
        System.out.println("Circle inherited from shape interface");
    }
    
    void triangle(){   //we can also create a own method within the class
        System.out.println("Triangle method - within Main class");
    }
    
	public static void main(String[] args) {
	    
	    shape sc = new Main();  /* One of the feature of interface is that we can create a referance variable for interface but we cannot create a object for interface
	                               its like  shape is interface name and sc is referance variable for the object created. Object created (new Main()) */
	    
	    sc.rectangle();   /* as object is created in class and declared interface as referance variable -> we can declare as sc.rectangle()
	                         if we want to access or print the values of the method.*/
	    sc.circle();
	    sc.triangle();  /*even though we had created a object with interface variable as referance -> we cannot able to access the
	                      individual own method declared in the class using the interface referance variable.*/
	    
	    shape.square();  //as a static method declared in parent interface, we can use the class name in which this method is declared as static for accessing the values

		int multiple = sc.length * sc.widgth;  //as this variables are declared in interface we can access these variables using interface referance variables
	    System.out.println(multiple);
	    
	    int sum = shape.length + shape.widgth;  //we can also access these variables using the interface name
	    System.out.println(sum);
	}
}

