//enter an multiple array elements using Scanner method

package SampleTest;

import java.lang.reflect.Array;
import java.util.Arrays;
import java.util.Scanner;

public class Arraylist {
	public static void main(String[] args) {
		int a[] = new int[5];
		Scanner sc = new Scanner(System.in);
		
		for (int i=0 ; i<a.length; i++) {
			System.out.print("Enter the number that will store the value in the index "+i+" : ");
			a[i] = sc.nextInt();
		}
		System.out.println("Elements sorted in the array "+Arrays.toString(a));
}
}

